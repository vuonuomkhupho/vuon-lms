      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:station.railway.com)",
      "Bash(git init:*)",
      "Bash(git checkout:*)",
      "Bash(git remote:*)",
      "Bash(git push:*)",
      "Bash(railway whoami:*)",
