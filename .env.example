# ─── Vuon LMS Environment Variables ───

# Docker image (after running ./scripts/build-image.sh)
CUSTOM_IMAGE=vuon-lms:latest

# Database
DB_PASSWORD=change_me_to_a_strong_password

# Frappe site
FRAPPE_SITE_NAME=lms.localhost
ADMIN_PASSWORD=admin_password_here

# HTTP port (local access)
HTTP_PORT=8080

# ─── Cloudflare R2 Storage ───
# Configure these in Frappe UI: DFP External Storage settings
# These are here for reference only
#
# R2_BUCKET_NAME=vuon-lms-media
# R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_REGION=auto
